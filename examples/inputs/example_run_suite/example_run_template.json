{
  "run_name": "example_suite_cpu",
  "python": "python",
  "jax_mode": "cpu",
  "jax_dtype": "float64",
  "c_ref_dir": "",
  "api_benchmark": {
    "enabled": true,
    "warmup": 1,
    "runs": 5
  },
  "matrix_diagnostics": {
    "enabled": true,
    "n": 8,
    "repeats": 4
  },
  "profiles": [
    {
      "name": "core",
      "functions": "exp,log,sqrt,sin,cos,tan,sinh,cosh,tanh",
      "samples": "300,600",
      "seeds": "0,1",
      "prec_bits": 200
    },
    {
      "name": "hypgeom_robust",
      "functions": "gamma,erf,erfc,besselj,bessely,besseli,besselk,CubesselK",
      "samples": "240,480",
      "seeds": "0,1",
      "prec_bits": 256
    }
  ]
}
